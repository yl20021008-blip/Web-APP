# Supabase/PostgreSQL connection string.
# 可以直接复用 Streamlit Secrets 里的 DATABASE_URL。
# 如果是 postgresql+psycopg2:// 开头，代码会自动转换成 postgresql://。
DATABASE_URL="postgresql+psycopg2://postgres.xxxxx:your-password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require"

# 用于签名登录 cookie。自己随便生成一串长字符串。
AUTH_SECRET="change-this-to-a-long-random-secret"

# 和 Streamlit 版保持一致，才能兼容已有用户 PIN。
PIN_PEPPER="ielts-vocabulary-app-v1.2"

# 可选：管理员 PIN。v2.0 Web 学习端暂不开放公共词库编辑。
ADMIN_PIN="change-this-admin-pin"

# 生产环境必须是 production。
NODE_ENV="production"
